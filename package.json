{
  "name": "lab-attendance-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite\" \"tsc -p electron/tsconfig.json -w\" \"wait-on http://127.0.0.1:5173 && node scripts/start-electron-dev.cjs\"",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "clean:release": "node scripts/clean-release.cjs",
    "dist": "npm run clean:release && npm run build && electron-builder --win nsis && node scripts/make-release-zip.cjs",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit && tsc -p electron/tsconfig.json --noEmit"
  },
  "build": {
    "appId": "io.github.erinneria.lab-attendance-assistant",
    "productName": "Lab Attendance Assistant",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "artifactName": "LabAttendanceAssistant-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@types/mailparser": "^3.4.6",
    "element-plus": "^2.8.7",
    "exceljs": "^4.4.0",
    "imapflow": "^1.3.2",
    "jszip": "^3.10.1",
    "mailparser": "^3.9.8",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pinia": "^2.2.6",
    "puppeteer": "^24.42.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10",
    "wait-on": "^8.0.1"
  }
}
